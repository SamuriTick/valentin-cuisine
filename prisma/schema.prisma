generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── AUTH ──────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  password      String?
  role          String    @default("admin")
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  accounts      Account[]
  sessions      Session[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verificationtokens")
}

// ── CONTENT ───────────────────────────────────────────────────────────────────

// All editable site copy — homepage text, labels, descriptions
// key examples: "hero.title", "about.body1", "site.tagline"
model SiteContent {
  id        Int      @id @default(autoincrement())
  key       String
  lang      String   @default("en")
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([key, lang])
  @@map("site_content")
}

// Dynamic pages Valentin can create from admin
// Rendered at /[slug] using a shared template
// showInNav=true → appears in nav bar automatically
model Page {
  id         Int      @id @default(autoincrement())
  title      String
  slug       String   @unique
  content    String
  showTitle  Boolean  @default(true) @map("show_title")
  showInNav  Boolean  @default(false) @map("show_in_nav")
  navOrder   Int      @default(99) @map("nav_order")
  topLevel   Boolean  @default(false) @map("top_level")
  published  Boolean  @default(false)
  deletedAt  DateTime? @map("deleted_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("pages")
}

// category: recipe | news | achievement | experience | update
// recipe + news + update  → /blog
// achievement + experience → /credentials
model Post {
  id          Int       @id @default(autoincrement())
  title       String
  slug        String    @unique
  excerpt     String?
  content     String
  imageUrl    String?   @map("image_url")
  category    String    @default("news")
  tags        String?
  featured    Boolean   @default(false)
  published   Boolean   @default(false)
  publishedAt DateTime? @map("published_at")
  viewCount   Int       @default(0) @map("view_count")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("posts")
}

// category: cake | pastry | bread | fermented | seasonal
model Product {
  id           Int      @id @default(autoincrement())
  name         String
  description  String?
  price        String?
  imageUrl     String?  @map("image_url")
  category     String   @default("cake")
  available    Boolean  @default(true)
  featured     Boolean  @default(false)
  orderNote    String?  @map("order_note")
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("products")
}

// Verified references — displayed as "References upon request"
// Visitors can contact them directly to verify
model Reference {
  id           Int      @id @default(autoincrement())
  name         String
  role         String?
  company      String?
  phone        String?
  email        String?
  website      String?
  quote        String?  // optional short endorsement if they provide one
  active       Boolean  @default(true)
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("references")
}

// Handles gallery images + CV PDF uploads
// fileType: image | pdf
// tags: gallery | cv | certificate | press
model MediaItem {
  id           Int      @id @default(autoincrement())
  filename     String
  originalName String   @map("original_name")
  filePath     String   @map("file_path")
  fileType     String   @map("file_type")
  fileSize     Int?     @map("file_size")
  altText      String?  @map("alt_text")
  caption      String?
  tags         String?
  featured     Boolean  @default(false)
  width        Int?
  height       Int?
  uploadedAt   DateTime @default(now()) @map("uploaded_at")

  @@map("media_library")
}
